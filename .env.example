# =============================================================================
# auto-proxy-cloudflare configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Cloudflare credentials (choose ONE method)
# -----------------------------------------------------------------------------

# Option A: API Token (recommended — create at https://dash.cloudflare.com/profile/api-tokens)
# Required permissions: Zone > DNS > Edit  (scoped to your zone(s))
CF_API_TOKEN=your_cloudflare_api_token_here

# Option B: Global API Key (legacy)
# CF_API_KEY=your_global_api_key_here
# CF_EMAIL=your_cloudflare_account_email@example.com

# -----------------------------------------------------------------------------
# Domains to monitor
# -----------------------------------------------------------------------------

# Comma-separated list of fully-qualified domain names (subdomains or apex)
DOMAINS=sub1.example.com,sub2.example.com

# -----------------------------------------------------------------------------
# Polling interval
# -----------------------------------------------------------------------------

# How often to check each domain, in seconds. Default: 300 (5 minutes)
CHECK_INTERVAL=300

# -----------------------------------------------------------------------------
# Discord notifications (optional)
# -----------------------------------------------------------------------------

# Webhook URL to receive notifications when a domain gets blocked or unblocked.
# Leave empty (or remove) to disable notifications.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Log level: DEBUG | INFO | WARNING | ERROR  (default: INFO)
# LOG_LEVEL=INFO
